# Google Service Account credentials
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable Google Sheets API on the project
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The ID from your Google Sheet URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
# Share the sheet with the service account email (Viewer role)
GOOGLE_SHEET_ID=your_sheet_id_here

# Supabase – used for CV file storage
# Find these in your Supabase project: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your_supabase_service_role_key
